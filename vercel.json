{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/generate.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "AQUA_API_KEY": "@aqua_api_key"
  }
}
